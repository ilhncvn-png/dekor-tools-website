{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/patterns/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Baloo 2|Nunito))/i]",
        "message": "Font not provided by the design system. Available: Baloo 2, Nunito."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|ring|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='ring'] > Literal[value!=/^(?:sky|coral|mint|sun|pink|grape)$/]",
        "message": "<Avatar> ring must be one of 'sky' | 'coral' | 'mint' | 'sun' | 'pink' | 'grape'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|variant|size|iconLeft|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, color, variant, size, iconLeft, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:sky|coral|mint|sun|pink|grape|ink)$/]",
        "message": "<Badge> color must be one of 'sky' | 'coral' | 'mint' | 'sun' | 'pink' | 'grape' | 'ink'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|solid|outline)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'solid' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|pill|iconLeft|iconRight|fullWidth|disabled|as|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, pill, iconLeft, iconRight, fullWidth, disabled, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|sunshine|whatsapp|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'sunshine' | 'whatsapp' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:button|a)$/]",
        "message": "<Button> as must be one of 'button' | 'a'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|accent|interactive|padding|radius|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, accent, interactive, padding, radius, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:sky|coral|mint|sun|pink|grape)$/]",
        "message": "<Card> accent must be one of 'sky' | 'coral' | 'mint' | 'sun' | 'pink' | 'grape'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|color|dot|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, color, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='color'] > Literal[value!=/^(?:sky|coral|mint|sun|pink|grape)$/]",
        "message": "<Eyebrow> color must be one of 'sky' | 'coral' | 'mint' | 'sun' | 'pink' | 'grape'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|accent|style|key|ref|className|style|children)$/]",
        "message": "<FeatureCard> doesn't accept that prop. Declared props: icon, title, description, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:sky|coral|mint|sun|pink|grape)$/]",
        "message": "<FeatureCard> accent must be one of 'sky' | 'coral' | 'mint' | 'sun' | 'pink' | 'grape'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|type|placeholder|iconLeft|required|textarea|rows|id|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, type, placeholder, iconLeft, required, textarea, rows, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgramCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|description|accent|style|key|ref|className|style|children)$/]",
        "message": "<ProgramCard> doesn't accept that prop. Declared props: icon, title, description, accent, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgramCard'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:sky|coral|mint|sun|pink|grape)$/]",
        "message": "<ProgramCard> accent must be one of 'sky' | 'coral' | 'mint' | 'sun' | 'pink' | 'grape'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|size|showValue|style|key|ref|className|style|children)$/]",
        "message": "<StarRating> doesn't accept that prop. Declared props: value, max, size, showValue, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TestimonialCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:quote|name|relation|rating|avatar|ring|style|key|ref|className|style|children)$/]",
        "message": "<TestimonialCard> doesn't accept that prop. Declared props: quote, name, relation, rating, avatar, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TestimonialCard'] > JSXAttribute[name.name='ring'] > Literal[value!=/^(?:sky|coral|mint|sun|pink|grape)$/]",
        "message": "<TestimonialCard> ring must be one of 'sky' | 'coral' | 'mint' | 'sun' | 'pink' | 'grape'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
