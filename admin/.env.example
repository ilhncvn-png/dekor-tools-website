# Copy to .env.local for local dev, or set in Vercel's encrypted env var
# store for preview/production. Never commit real values.

# --- Database (Neon / Supabase Postgres / Vercel Postgres) ---
# Pooled connection (used by the app at runtime, serverless-safe).
DATABASE_URL=
# Direct (unpooled) connection, used only by `prisma migrate`.
DIRECT_URL=

# --- Authentication ---
# Long random secret used to sign session tokens. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=

# --- Media storage (Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=

# --- URLs ---
# This admin app's own public URL (used to build absolute links/redirects).
APP_URL=
# The public marketing site's URL (used for revalidation calls + preview links).
PUBLIC_SITE_URL=

# --- Preview & revalidation ---
# Long random secret used to sign short-lived draft-preview links.
PREVIEW_SECRET=
# Long random secret required by the public site's /api/revalidate endpoint.
REVALIDATION_SECRET=

# --- Initial admin seed (used only by `prisma/seed.ts`, never at runtime) ---
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# --- Auth mode flag ---
# "true" activates the real PostgreSQL-backed auth (requires DATABASE_URL,
# DIRECT_URL, AUTH_SECRET above). Anything else (or unset) keeps the
# TEMPORARY legacy-recovery login active — see below. Flip to "true" ONLY
# after the real production admin account has been seeded and verified.
CMS_DATABASE_AUTH_ENABLED=

# --- TEMPORARY legacy-recovery login (active while CMS_DATABASE_AUTH_ENABLED
# is not "true"). Lets the operator regain access to the live admin without
# the full production Postgres/Blob stack. Remove both once real DB auth is
# verified. The hash is an Argon2id hash of your chosen password — generate
# it with:  node scripts/hash-password.mjs
LEGACY_ADMIN_EMAIL=
LEGACY_ADMIN_PASSWORD_HASH=
